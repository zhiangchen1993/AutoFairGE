<SVC> ::= SVC(C=<SVC_C>, kernel=<SVC_kernel>, gamma=<SVC_gamma>, class_weight=<class_weight>, random_state=0)
<SVC_kernel> ::= "'linear'" | "'rbf'" | "'sigmoid'" | "'poly'"
<SVC_C> ::= 1e-2 | 1e-1 | 1 | 1e1 | 1e2 | 1e3
<SVC_gamma> ::= "'scale'" | "'auto'" | 1e-2 | 1e-1 | 1 | 1e1 | 1e2

<class_weight> ::= None | "'balanced'" | {0: 0.05, 1: 0.95} | {0: 0.1, 1: 0.9} | {0: 0.15, 1: 0.85} | {0: 0.2, 1: 0.8} |
 {0: 0.25, 1: 0.75} | {0: 0.3, 1: 0.7} | {0: 0.35, 1: 0.65} | {0: 0.4, 1: 0.6} | {0: 0.45, 1: 0.55} | {0: 0.5, 1: 0.5} |
 {0: 0.55, 1: 0.45} | {0: 0.6, 1: 0.4} | {0: 0.65, 1: 0.35} | {0: 0.7, 1: 0.3} | {0: 0.75, 1: 0.25} | {0: 0.8, 1: 0.2} |
 {0: 0.85, 1: 0.15} | {0: 0.9, 1: 0.1} | {0: 0.95, 1: 0.05}
